# =====================================================================
# Browser Agent Runtime Platform - .gitignore(合并版)
# =====================================================================
# 合并来源:
#   1) 原根目录 .gitignore(Codex 协作上下文 / AI 助手配置)
#   2) backend/.gitignore(Python / 后端运行时产物)
#   3) frontend/.gitignore(Node / Next.js 前端产物)
#
# 提醒: .gitignore 本身是项目源码,**应该**提交到仓库。
# 它定义的是哪些文件不提交,而不是说本文件不提交。
# =====================================================================

# --- Codex 协作上下文(个人学习用,非项目源码) ---
AGENTS.md
docs/AI协作式*.md

# --- 设计稿 / 文档产物(非源码) ---
frontend/docs/*.zip
frontend/docs/*.html
frontend/docs/*.png

# --- AI 助手配置(个人学习用,非项目源码) ---
.claude/
CLAUDE.md
.trae-cn/

# --- 依赖 ---
node_modules/
.pnpm-store/
.venv/

# --- Python 生成文件 ---
__pycache__/
*.py[oc]
*.pyd
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- 前端构建产物 ---
.next/
out/
# dist/ 和 build/ 在前后端都会出现(Next.js / Python packaging),统一在下一节处理

# --- 构建产物(前后端共用) ---
dist/
build/
wheels/

# --- 环境变量(不提交) ---
.env
.env.local
.env.*.local

# --- 日志 / 调试 ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- IDE / 编辑器 ---
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# --- 系统 ---
.DS_Store
Thumbs.db

# --- 测试覆盖率 / 测试产物 ---
coverage/
htmlcov/
*.cover
.tox/
.nox/
.pytest_cache/
.coverage
.coverage.*
playwright-report/
test-results/

# --- 类型检查 / Linter 缓存 ---
*.tsbuildinfo
.mypy_cache/
.pyright_cache/
.ruff_cache/

# --- 本地数据 / 运行时产物(V1 本地存储 + Worker stderr) ---
# 这些是运行时产物,不属于源码,绝不能 commit
*.sqlite
*.sqlite3
*.db
minio/data/
data/
logs/

# --- Lock 文件(本地依赖锁定,按需提交) ---
uv.lock
poetry.lock
Pipfile.lock
