# =====================================================================
# Browser Agent Runtime Platform - .env.example
# =====================================================================
# 使用方法:
#   cp .env.example .env
#   然后填入真实密钥
# 不要把 .env 提交到 git
# =====================================================================

# --- 服务 ---
APP_NAME=browser-agent-runtime
ENVIRONMENT=dev
LOG_LEVEL=INFO

# --- CORS ---
# 允许跨域调用的前端 origin,逗号分隔。生产环境必须改成真实域名。
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_dev_password
POSTGRES_DB=agent_runtime
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
# ⚠️ 以下是 dev 默认值,生产环境必须覆盖成强密码,否则 MinIO 暴露在公网会被秒入侵
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_SCREENSHOTS=screenshots
S3_BUCKET_FILES=files
S3_REGION=us-east-1

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- LLM ---
LLM_PROVIDER=deepseek
# DeepSeek 走 OpenAI 兼容协议,在 https://platform.deepseek.com 申请
LLM_API_KEY=<your-deepseek-key>
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_DEFAULT_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# --- LangSmith(LangChain 可观测性,可选) ---
# 设为 true 即开启 LangSmith trace,业务代码无需改动
# 去 https://smith.langchain.com 申请 key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=<your-langsmith-key>
# LANGCHAIN_PROJECT=browser-agent-runtime
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- 浏览器 (Phase 1+) ---
BROWSER_HEADLESS=true
BROWSER_MAX_CONTEXTS=10
BROWSER_CONTEXT_IDLE_TIMEOUT=300
